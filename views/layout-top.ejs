<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %> | LMLinga Barangay Health</title>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<div class="layout">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <img src="/img/logo.png" alt="LMLinga" class="logo-img"/>
      <div>
        <div class="logo-text">LMLinga</div>
        <div class="logo-sub">Barangay Health System</div>
      </div>
    </div>

    <nav class="sidebar-nav">
      <div class="nav-section">
        <div class="nav-section-title">Main</div>
        <ul>
          <li class="nav-item">
            <a href="/dashboard" class="<%= active==='dashboard'?'active':'' %>">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
              Dashboard
            </a>
          </li>
        </ul>
      </div>
      <div class="nav-section">
        <div class="nav-section-title">Records</div>
        <ul>
          <% if(user && user.role === 'Administrator') { %>
          <li class="nav-item">
            <a href="/users" class="<%= active==='users'?'active':'' %>">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              User Management
            </a>
          </li>
          <% } %>
          <li class="nav-item">
            <a href="/household" class="<%= active==='household'?'active':'' %>">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              Household Profiling
            </a>
          </li>
          <li class="nav-item">
            <a href="/residents" class="<%= active==='residents'?'active':'' %>">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              Resident Records
            </a>
          </li>
        </ul>
      </div>
      <div class="nav-section">
        <div class="nav-section-title">Health Services</div>
        <ul>
          <li class="nav-item"><a href="/health/immunization" class="<%= active==='immunization'?'active':'' %>">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>Immunization</a></li>
          <li class="nav-item"><a href="/health/operation-timbang" class="<%= active==='timbang'?'active':'' %>">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M8 12h8"/><path d="M12 8v8"/></svg>Operation Timbang</a></li>
          <li class="nav-item"><a href="/health/vitamin-a" class="<%= active==='vitamin-a'?'active':'' %>">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>Vitamin A</a></li>
          <li class="nav-item"><a href="/health/deworming" class="<%= active==='deworming'?'active':'' %>">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/></svg>Deworming</a></li>
          <li class="nav-item"><a href="/health/risk-assessment" class="<%= active==='risk-assessment'?'active':'' %>">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>Risk Assessment</a></li>
          <li class="nav-item"><a href="/health/family-planning" class="<%= active==='family-planning'?'active':'' %>">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>Family Planning</a></li>
        </ul>
      </div>
    </nav>

    <div class="sidebar-footer">
      <div class="sidebar-user">
        <div class="avatar"><%= user ? user.name.charAt(0).toUpperCase() : 'U' %></div>
        <div class="sidebar-user-info">
          <div class="name"><%= user ? user.name : 'User' %></div>
          <div class="role"><%= user ? user.role : '' %></div>
        </div>
      </div>
      <a href="/logout" class="btn btn-outline btn-sm w-full">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Logout
      </a>
    </div>
  </aside>

  <!-- MAIN -->
  <div class="main">
    <header class="topbar">
      <div class="topbar-title"><%= title %></div>
      <div class="topbar-right">
        <div class="topbar-search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <input type="text" placeholder="Search..."/>
        </div>
        <div class="topbar-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        </div>
        <div class="avatar" style="cursor:pointer"><%= user ? user.name.charAt(0).toUpperCase() : 'U' %></div>
      </div>
    </header>

    <div class="page-content">

      <!-- FLASH MESSAGES -->
      <% if(success && success.length > 0) { %>
        <div class="flash flash-success">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <%= success[0] %>
          <button onclick="this.parentElement.remove()" class="flash-close">✕</button>
        </div>
      <% } %>
      <% if(error && error.length > 0) { %>
        <div class="flash flash-error">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <%= error[0] %>
          <button onclick="this.parentElement.remove()" class="flash-close">✕</button>
        </div>
      <% } %>
