<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Forgot Password | LMLinga Barangay Health</title>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body class="auth-body">
<div class="auth-card">
  <div class="auth-logo">
    <img src="/img/logo.png" alt="LMLinga Logo" class="auth-logo-img"/>
    <h2>LMLinga</h2>
    <p>Barangay Health Management System</p>
  </div>
  <h3>Reset Your Password</h3>
  <p style="font-size:13px;color:var(--gray-500);text-align:center;margin-bottom:20px;">Enter your email and we'll send you a reset link.</p>
  <form action="/forgot-password" method="POST">
    <div class="form-group"><label>Email Address</label><input type="email" name="email" required placeholder="Enter your registered email"/></div>
    <button type="submit" class="btn btn-primary btn-block">Send Reset Link</button>
  </form>
  <div class="auth-link">Remembered your password? <a href="/login">Sign In</a></div>
</div>
</body>
</html>
